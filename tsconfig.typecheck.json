{
  "extends": "./tsconfig.json",
  "include": [
    "next-env.d.ts",
    "src/api/**/*.ts",
    "src/http/**/*.ts",
    "src/env.ts",
    "src/api-env.ts",
    "src/app/(board)/**/*.tsx",
    "src/app/@modal/**/*.tsx",
    "src/app/api/**/*.ts",
